<?xml version="1.0" encoding="utf-8"?>
<!-- Branded unlock prompt shown when the vault is locked. Uses a
     generic lock vector (not the launcher icon) so the row's semantic
     reads as "this credential store is locked" rather than "here is
     the VaultSnap app icon" — clearer affordance, fewer redundant
     brand marks (header already carries the brand). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/autofill_row_bg"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/autofill_brand_circle"
        android:layout_marginEnd="12dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_autofill_lock"
            android:tint="@color/autofill_brand"
            android:contentDescription="@null" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/autofill_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:ellipsize="end"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/autofill_text"
            android:text="@string/autofill_unlock_prompt" />

        <TextView
            android:id="@+id/autofill_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:ellipsize="end"
            android:textSize="12sp"
            android:textColor="@color/autofill_text_dim"
            android:text="@string/autofill_unlock_subtitle"
            android:layout_marginTop="1dp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="UNLOCK"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:textColor="@color/autofill_brand"
        android:paddingStart="10dp"
        android:paddingEnd="6dp" />
</LinearLayout>

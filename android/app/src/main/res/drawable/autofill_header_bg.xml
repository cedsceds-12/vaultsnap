<?xml version="1.0" encoding="utf-8"?>
<!-- Header background for the autofill drop-down — solid surface with a
     bottom hairline divider so the brand row reads as a header rather
     than another suggestion. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/autofill_bg" />
        </shape>
    </item>
    <item android:top="-1dp" android:left="-1dp" android:right="-1dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="@color/autofill_divider" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
